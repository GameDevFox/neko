#!/usr/bin/env python3
import subprocess
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer

if len(sys.argv) < 2:
    print("Usage: ding-server <audio-file> [port]", file=sys.stderr)
    sys.exit(1)

SOUND = sys.argv[1]
PORT = int(sys.argv[2]) if len(sys.argv) > 2 else 8765


class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == "/ding":
            subprocess.Popen(["mpv", SOUND])
            self.send_response(200)
            self.end_headers()
            self.wfile.write(b"ding!\n")
        else:
            self.send_response(404)
            self.end_headers()

    def log_message(self, fmt, *args):
        print(f"{self.address_string()} - {fmt % args}")


print(f"Listening on :{PORT} — GET /ding to play the sound")
HTTPServer(("", PORT), Handler).serve_forever()
