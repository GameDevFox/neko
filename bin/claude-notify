#!/bin/bash
# Send a Telegram message via the Claude bot
# Usage: claude-notify "message text"

TOKEN=$(cat ~/claude-telegram-bot-token)
CHAT=$(cat ~/claude-telegram-chat-id)
MSG="${1:-Done}"

curl -s -X POST "https://api.telegram.org/bot$TOKEN/sendMessage" \
  -d "chat_id=$CHAT" \
  --data-urlencode "text=$MSG" \
  > /dev/null
